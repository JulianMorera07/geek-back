# App
APP_NAME=geekbaku-backend
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# Auth / JWT
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# CORS
CORS_ALLOW_ORIGINS=["*"]
